# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# Optional fallback if the SRV/DNS lookup fails on the host (e.g. some PaaS networks)
MONGO_URI_DIRECT=
MONGO_DNS_SERVERS=

# Auth (JWT)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-frontend.vercel.app

# Email (OTP delivery, order notifications) - Gmail app password or SMTP-compatible provider
EMAIL_USER=
EMAIL_PASS=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional access restrictions
ALLOWED_COLLEGE_DOMAINS=
ALLOWED_EMAILS=
